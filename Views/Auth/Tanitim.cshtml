@{
    ViewData["Title"] = "Tanıtım";
}

<!DOCTYPE html>
<html>
<head>
    <style>
        body {
            font-family: Arial;
            background-color: #f5f5f5;
            text-align: center;
        }

        .container {
            margin-top: 100px;
        }

        h1 {
            color: #333;
        }

        p {
            color: #666;
            font-size: 18px;
        }

        .btn {
            margin-top: 20px;
            padding: 10px 20px;
            background-color: #007bff;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        .btn:hover {
            background-color: #0056b3;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>Hoş Geldiniz 👋</h1>
        <p>Giriş işleminiz başarılı!</p>
        <p>Burası tanıtım sayfasıdır. Arkadaşınız tarafından geliştirilmiştir.</p>

        <button class="btn" onclick="alert('Devam ediliyor...')">
            Devam Et
        </button>
    </div>

</body>
</html>